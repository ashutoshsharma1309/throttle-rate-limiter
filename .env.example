# ── Throttle configuration ──────────────────────────────────────────────────
# Copy to .env (docker-compose reads these). All values shown are defaults.

# Runtime
NODE_ENV=development
LOG_LEVEL=info            # pino level: trace|debug|info|warn|error

# Transports
HTTP_PORT=8080            # Fastify REST listener
GRPC_PORT=50051           # @grpc/grpc-js listener

# Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_CLUSTER=false       # true => connect in Redis Cluster mode
REDIS_COMMAND_TIMEOUT_MS=50   # per-command timeout; a slow Redis == a down Redis

# Resilience
FAIL_OPEN=true            # true => allow on Redis failure; false => 503 / UNAVAILABLE

# Admin API (tenant/rule management) — set a strong value in production
ADMIN_API_KEY=dev-admin-key-change-me

# Rule cache
RULE_CACHE_TTL_MS=30000   # in-process rule cache TTL (staleness window)
